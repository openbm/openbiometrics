{
  "name": "openbiometrics",
  "version": "0.1.0",
  "description": "OpenBiometrics SDK — face recognition, liveness, and biometric verification for your apps",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "biometrics",
    "face-recognition",
    "liveness",
    "face-detection",
    "openbiometrics"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8",
    "typescript": "^5"
  }
}
